# ─── Competitor Website Builder – Produktions-Umgebungsvariablen ─────────────
# Kopiere diese Datei nach .env und befülle alle Werte:
#   cp deploy/.env.production.template .env
#
# WICHTIG: .env niemals in Git committen!

# ─── Datenbank ────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=sicheres_root_passwort_hier_eintragen
MYSQL_DATABASE=competitor_builder
MYSQL_USER=appuser
MYSQL_PASSWORD=sicheres_db_passwort_hier_eintragen

# ─── App-Sicherheit ───────────────────────────────────────────────────────────
# Zufälligen 64-Zeichen-String generieren: openssl rand -hex 32
JWT_SECRET=dein_jwt_secret_hier_eintragen

# ─── Manus OAuth (für Login) ──────────────────────────────────────────────────
# Aus den Manus-Projekteinstellungen kopieren
VITE_APP_ID=deine_manus_app_id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im
OWNER_OPEN_ID=deine_manus_open_id
OWNER_NAME=Dein Name

# ─── Manus Built-in LLM (für "Manus"-Provider) ───────────────────────────────
# Aus den Manus-Projekteinstellungen kopieren
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=dein_forge_api_key
VITE_FRONTEND_FORGE_API_KEY=dein_frontend_forge_key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im

# ─── Google Gemini (für "Gemini"-Provider, optional) ─────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=dein_gemini_api_key

# ─── Anthropic Claude (für "Claude"-Provider, optional) ──────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=dein_anthropic_api_key
