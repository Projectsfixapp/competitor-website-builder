# ─── Competitor Website Builder – Produktions-Umgebungsvariablen ─────────────
# Kopiere diese Datei nach .env und befülle alle Werte:
#   cp deploy/.env.production.template .env
#
# WICHTIG: .env niemals in Git committen!

# ─── Datenbank ────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=sicheres_root_passwort_hier_eintragen
MYSQL_DATABASE=competitor_builder
MYSQL_USER=appuser
MYSQL_PASSWORD=sicheres_db_passwort_hier_eintragen

# ─── App-Sicherheit ───────────────────────────────────────────────────────────
# Zufälligen 64-Zeichen-String generieren: openssl rand -hex 32
JWT_SECRET=dein_jwt_secret_hier_eintragen
OWNER_EMAIL=deine@email.de

# ─── Cloudflare R2 (Objekt-Storage für Logo-/Bilder-Uploads) ─────────────────
# Cloudflare Dashboard → R2 → Bucket anlegen → "Manage R2 API Tokens" → Token
# erstellen (Berechtigung: Object Read & Write, gescoped auf den Bucket).
# Account-ID steht oben rechts im R2-Dashboard.
R2_ACCOUNT_ID=deine_cloudflare_account_id
R2_ACCESS_KEY_ID=dein_r2_access_key_id
R2_SECRET_ACCESS_KEY=dein_r2_secret_access_key
R2_BUCKET_NAME=competitor-website-builder
# Bucket-Einstellungen → Public Development URL aktivieren (oder eigene Domain
# verbinden) und die resultierende Basis-URL hier eintragen, z.B.
# https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_URL_BASE=https://pub-xxxxxxxx.r2.dev

# ─── Google Gemini (Bild-Fallback PFLICHT, Text-Provider optional) ───────────
# Wird IMMER fuer die KI-Bild-Fallback-Generierung genutzt (server/geminiImages.ts),
# unabhaengig vom gewaehlten Analyse-Provider. Ohne Key: foto-freies Design statt Fotos.
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=dein_gemini_api_key

# ─── Anthropic Claude (Standard-Provider für Analyse & Generierung) ─────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=dein_anthropic_api_key
